{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "linen": {
        "50": { "$value": "#FAF6EE", "$type": "color" },
        "100": { "$value": "#F2EBDA", "$type": "color" },
        "300": { "$value": "#E2D5B8", "$type": "color" },
        "500": { "$value": "#9C9080", "$type": "color" },
        "900": { "$value": "#241F1A", "$type": "color" }
      },
      "marine": {
        "500": { "$value": "#1D6E86", "$type": "color" },
        "700": { "$value": "#124A5C", "$type": "color" },
        "900": { "$value": "#0B2E3A", "$type": "color" }
      },
      "terracotta": {
        "500": { "$value": "#C1502E", "$type": "color" },
        "700": { "$value": "#8A3A22", "$type": "color" },
        "900": { "$value": "#4E1F12", "$type": "color" }
      },
      "gold": {
        "400": { "$value": "#D9A441", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-plex-mono), 'IBM Plex Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1s", "$type": "duration" },
        "crossfade": { "$value": "900ms", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "tide": { "$value": "cubic-bezier(0.45, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.16em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.linen.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.linen.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.linen.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.linen.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.linen.100}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.linen.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.linen.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.linen.900}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "input": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "radius": { "$value": "0.75rem", "$type": "dimension" },
    "marine": { "$value": "{primitive.color.marine.500}", "$type": "color" },
    "marine-dim": { "$value": "{primitive.color.marine.900}", "$type": "color" },
    "terracotta": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "gold": { "$value": "{primitive.color.gold.400}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-tide": { "$value": "{primitive.motion.ease.tide}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "duration-crossfade": { "$value": "{primitive.motion.duration.crossfade}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.75rem, 6.4vw, 5.25rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.02", "$type": "number" },
      "kicker-size": { "$value": "0.7rem", "$type": "dimension" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.linen.900}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.linen.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.linen.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.linen.300}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.marine.500}", "$type": "color" }
    },
    "rail": {
      "track-color": { "$value": "{primitive.color.linen.300}", "$type": "color" },
      "dot-color": { "$value": "{primitive.color.linen.500}", "$type": "color" },
      "dot-active-color": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "line-active-color": { "$value": "{primitive.color.marine.500}", "$type": "color" }
    }
  }
}
